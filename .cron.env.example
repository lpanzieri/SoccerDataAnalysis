# Copy to .cron.env and set real secrets.
# Keep permissions strict: chmod 600 /home/lpanzieri/Data-Analysis/.cron.env

export MYSQL_PASSWORD='replace_me'
export APIFOOTBALL_KEY='replace_me'

# Helper response cache (stored in MySQL table helper_response_cache)
# export HELPER_RESPONSE_CACHE_ENABLED='1'
# export HELPER_RESPONSE_CACHE_TTL_SECONDS='86400'

# Requeue in_progress tasks older than this many minutes at worker startup.
# Useful after power loss/reboots to resume automatically.
# export STALE_IN_PROGRESS_MINUTES='90'

# Optional worker scope guardrails for unattended major-5 historical backfill.
# BACKFILL_SCOPE values:
#   - all (default): process any queued league task
#   - top5 or top5_2016_plus: process only E0, SP1, I1, D1, F1
# export BACKFILL_SCOPE='top5_2016_plus'
# Optional minimum season year; tasks below this year are skipped by worker.
# export BACKFILL_MIN_START_YEAR='2016'

# DB backup to SMB (mounted path expected)
# SMB URI reference only (for logs and clarity)
# export SMB_BACKUP_URI='smb://192.168.1.250/Software/mySQL_Backups'
# Local mount point where the SMB share is mounted
# export SMB_BACKUP_MOUNT_POINT='/mnt/mysql_backups'
# Subdirectory under mount point where backups are written
# export SMB_BACKUP_SUBDIR='mySQL_Backups'
# Keep only the newest N compressed SQL backups (oldest are deleted)
# export DB_BACKUP_MAX_FILES='20'

# Optional overrides (usually not needed)
# export MYSQL_HOST='127.0.0.1'
# export MYSQL_PORT='3306'
# export MYSQL_USER='football_admin'
# export MYSQL_DATABASE='historic_football_data'
